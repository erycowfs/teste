CREATE DATABASE store;

Tabelas:

CREATE TABLE users (

id INT AUTO_INCREMENT PRIMARY KEY,
email VARCHAR(255),
password VARCHAR(255),
role VARCHAR(50)

);

CREATE TABLE products (

id INT AUTO_INCREMENT PRIMARY KEY,
name VARCHAR(255),
price DECIMAL(10,2),
image TEXT,
category VARCHAR(100),
sales INT DEFAULT 0

);

CREATE TABLE cart (

id INT AUTO_INCREMENT PRIMARY KEY,
user_id INT,
product_id INT,
quantity INT

);